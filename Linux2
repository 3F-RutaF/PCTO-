#!/bin/bash

#
# USB-triggered backup + reset system
# Ubuntu/Linux
#

set +e

########################################
# CONFIG
########################################

USER_NAME=$(logname)
USER_HOME="/home/$USER_NAME"

TIMESTAMP=$(date +"%Y-%m-%d_%H-%M-%S")
BACKUP_NAME="${USER_NAME}_${TIMESTAMP}"

# USB device
USB_MOUNT=$(findmnt -rn -S /dev/sdb1 -o TARGET)

# Destination folder on USB
DEST="$USB_MOUNT/$BACKUP_NAME"

########################################
# CHECK USB
########################################

if [ -z "$USB_MOUNT" ]; then
    echo "No USB device detected."
    exit 1
fi

mkdir -p "$DEST"

echo "USB detected at: $USB_MOUNT"
echo "Backup folder: $DEST"

########################################
# COPY USER FILES
########################################

echo "Copying files..."

rsync -a --progress \
    --exclude=".cache" \
    --exclude=".local/share/Trash" \
    --exclude=".local/state" \
    --exclude="node_modules" \
    --exclude=".gvfs" \
    --exclude="Downloads/*.tmp" \
    --exclude="Singleton*" \
    --exclude="*.lock" \
    --exclude="*.sock" \
    --exclude=".config/google-chrome/*" \
    --exclude=".config/BraveSoftware/*" \
    --exclude="snap" \
    "$USER_HOME/" \
    "$DEST/" || true

echo "Copy complete."

########################################
# FORCE WRITE TO USB
########################################

echo "Flushing filesystem buffers..."

sync
udevadm settle

########################################
# UNMOUNT USB CLEANLY
########################################

echo "Unmounting USB..."

umount "$USB_MOUNT"

########################################
# DELETE USER FILES
########################################

echo "Deleting user files..."

rm -rf "$USER_HOME/Desktop/"*
rm -rf "$USER_HOME/Documents/"*
rm -rf "$USER_HOME/Downloads/"*
rm -rf "$USER_HOME/Pictures/"*
rm -rf "$USER_HOME/Videos/"*
rm -rf "$USER_HOME/Music/"*

########################################
# FINAL SYNC
########################################

sync

########################################
# REBOOT
########################################

echo "Rebooting system in 5 seconds..."

sleep 5

systemctl reboot -i
